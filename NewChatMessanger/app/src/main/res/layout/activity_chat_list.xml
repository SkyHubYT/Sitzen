<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/tm_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/tm_surface"
        android:title="Chats"
        android:titleTextColor="@color/tm_text_primary"
        android:navigationIcon="@android:drawable/ic_media_previous" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerThreads"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp" />
</LinearLayout>
